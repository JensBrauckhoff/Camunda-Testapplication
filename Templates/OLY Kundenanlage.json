{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "OLY Kundenanlage",
  "id": "OLY_KundenAnlage",
  "version": 4,
  "description": "Kundenanlage in Olympic",
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "category": {
    "id": "templates",
    "name": "Templates"
  },
  "groups": [
    {
      "id": "Kundendaten",
      "label": "Kundendaten",
      "openByDefault": true
    },
    {
      "id": "Ergebnis",
      "label": "Ergebnis on OLY",
      "openByDefault": true
    }
  ],
  "properties": [
    {
      "type": "String",
      "value": "OlyKundenAnlage",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "type"
      },
      "label": "Job type",
      "description": "Specify which job workers handle the task",
      "editable": false
    },
    {
      "type": "String",
      "value": "3",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "retries"
      },
      "label": "Retries",
      "description": "Number of retries for the task",
      "group": "templated-properties"
    },
    {
      "label": "Source variable for the input",
      "type": "String",
      "binding": {
        "type": "zeebe:input",
        "name": "kundenDaten"
      },
      "feel": "required",
      "group": "Kundendaten"
    },
    {
      "label": "Target variable for the output",
      "type": "String",
      "binding": {
        "type": "zeebe:output",
        "source": "olyAntwort"
      },
      "feel": "required",
      "group": "Ergebnis"
    }
  ],
  "icon": {
    "contents": "data:image/jpeg;base64,"
  }
}