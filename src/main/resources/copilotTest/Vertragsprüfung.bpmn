          <dc:Bounds x="-43" y="88" width="87" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_Response_di" bpmnElement="UserTask_Response">
        <dc:Bounds x="175" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_Email_di" bpmnElement="SendTask_Email">
        <dc:Bounds x="325" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1ocelps_di" bpmnElement="Gateway_1ocelps" isMarkerVisible="true">
        <dc:Bounds x="65" y="45" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="18" y="70" />
