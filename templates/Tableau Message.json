{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Tableau Message",
  "id": "message-intermediate-throw-event-template",
  "version": 1,
  "description": "Template, um eine Nachricht an Tableau zu senden",
  "appliesTo": [
    "bpmn:IntermediateThrowEvent"
  ],
  "elementType": {
    "value": "bpmn:IntermediateThrowEvent",
    "eventDefinition": "bpmn:MessageEventDefinition"
  },
  "category": {
    "id": "templates",
    "name": "Templates"
  },
  "groups": [
    {
      "id": "meldung",
      "label": "Meldung",
      "openByDefault": true
    }
  ],
  "properties": [
    {
      "type": "String",
      "feel": "required",
      "binding": {
        "name": "meldungsName",
        "type": "zeebe:input"
      },
      "label": "Meldungsname",
      "group": "meldung"
    },
    {
      "type": "Dropdown",
      "choices": [
        {
          "name": "START",
          "value": "START"
        },
        {
          "name": "STOP",
          "value": "STOP"
        }
      ],
      "binding": {
        "name": "meldungsType",
        "type": "zeebe:input"
      },
      "label": "Aktion",
      "group": "meldung"
    },
    {
      "type": "String",
      "value": "SendTableauMessage",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "type"
      },
      "label": "Job type",
      "editable": false
    },
    {
      "type": "Number",
      "value": "3",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "retries"
      },
      "label": "Retries",
      "description": "Number of retries for the job",
      "group": "templated-properties"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}